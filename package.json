{
  "name": "@duwab/test-kit",
  "version": "1.0.0",
  "description": "A npm package to help running e2e tests for NodeJS and Typescript micro-services for distributed architectures",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "docker-compose -f docker-compose.yml up -d && jest --testPathPattern=e2e && docker-compose -f docker-compose.yml down",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "test-kit",
    "e2e",
    "microservices",
    "rabbitmq",
    "redis",
    "elasticsearch"
  ],
  "author": "duwab",
  "license": "MIT",
  "dependencies": {
    "amqplib": "^0.10.3",
    "ioredis": "^5.3.2",
    "@elastic/elasticsearch": "^8.10.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "@types/amqplib": "^0.10.4",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
